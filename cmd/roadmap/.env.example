# Copy this file to `.env` for local development.
# The Go server loads `.env` automatically on startup.

# OAuth2 redirect URL registered with Google for this client.
For local development this should point at the locally running backend.
OAUTH2_CALLBACK=http://localhost:8080/api/v1/auth/oauth2callback

# Origin of the frontend dev server. Used for CORS and post-login redirects.
FRONTEND_URL=http://localhost:5173

# Port the backend listens on. Defaults to 8080 if unset.
# PORT=8080

# Path to a Google service account JSON key with access to the
# roadmap spreadsheet. Required by the /api/v1/timeline and /api/v1/update
# handlers. In production this is provided via app.yaml and points at a
# Cloud Storage object; locally a path to a downloaded key file is fine.
# AUSOCEAN_ROADMAP_CREDENTIALS=/absolute/path/to/service-account.json

# Path to the secrets file containing the OAuth client secret
# and session key. Only required if running the auth flow locally.
# AUSOCEAN_ROADMAP_SECRETS=/absolute/path/to/AusOceanRoadmap-secrets.txt
