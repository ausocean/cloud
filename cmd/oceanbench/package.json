{
  "type": "module",
  "scripts": {
    "build:css": "npx -y @tailwindcss/cli -i ./ts/tailwind.css -o ./s/dist/tailwind.global.css",
    "build": "npm run build:css && rollup -c",
    "build:watch": "npm run build:css -- --watch & rollup -c --watch",
    "format": "prettier --write \"**/*.html\"",
    "serve": "es-dev-server --node-resolve --watch",
    "deploy": "../../scripts/deploy.sh -b oceanbench",
    "deploy:dev": "../../scripts/deploy.sh -db oceanbench"
  },
  "dependencies": {
    "es-dev-server": "^2.1.0",
    "lit": "^2.6.1",
    "mime": "^3.0.0",
    "rollup-plugin-typescript2": "^0.34.1",
    "typescript": "^4.9.5"
  },
  "author": "AusOcean",
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.0.2",
    "@tailwindcss/cli": "^4.2.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "prettier": "^3.4.2",
    "rollup": "^3.21.5",
    "rollup-plugin-resolve": "^0.0.1-predev.1",
    "rollup-plugin-string": "^3.0.0",
    "stylelint": "^15.10.3",
    "stylelint-config-standard": "^34.0.0",
    "tailwindcss": "^4.2.1"
  }
}